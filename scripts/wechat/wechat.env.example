# wechat.env.example
# 复制为 wechat.env 并按需修改。该文件不会被 git 追踪（.gitignore 已排除）

# wechat-digest 仓库的本地路径（cliffyan28/wechat-digest）
WECHAT_DIGEST_DIR="$HOME/wechat-digest"

# 清洗后输出的根目录（每个群一个子目录）
OUTPUT_DIR="$HOME/wechat-data/cleaned"

# trading-review-wiki 的 raw/sources 目录
# 软链会落在 $WIKI_RAW_DIR/wechat/{群名}
WIKI_RAW_DIR="$HOME/wiki/raw/sources"

# 要抓的群（必须先在 wechat-digest 的 extract-messages.py 的 known 字典里登记）
# 群名 = 微信里的显示名
GROUPS=(
  "A股研究群"
  "光模块讨论组"
)

# 别名文件（可选）。{ "张三": "VIP_老张" }，没列出的会自动分配 用户A/B/C
ALIASES_FILE="$HOME/.config/trading-research-toolkit/aliases.json"

# 是否对昵称脱敏（1=启用，0=保留原昵称）
# 个人本地推荐 0；要分享给朋友的样本数据推荐 1
ANONYMIZE=0

# 给 extract-messages.py 用：0 = 抓全天，其他 = 只抓最近 N 小时（盘后追新可用 18）
HOUR_OFFSET=0

# 通知方式：auto = macOS osascript / Linux notify-send，off = 关闭
NOTIFY=auto

# Python 可执行文件（虚拟环境时改这里）
PYTHON=python3
