<?xml version="1.0" encoding="UTF-8"?>
<!--
 ============================================================
 zsxq-daily · macOS launchd 定时任务
 ------------------------------------------------------------
 安装步骤:
   1. cp 到 ~/Library/LaunchAgents/com.alleFind.zsxq-daily.plist
   2. 把所有 /Users/YOURNAME 替换为你的真实路径（whoami 查）
   3. launchctl load ~/Library/LaunchAgents/com.alleFind.zsxq-daily.plist
   4. launchctl start com.alleFind.zsxq-daily      ← 立即跑一次验证
   5. tail -f /tmp/zsxq-daily.log                  ← 看输出

 卸载:
   launchctl unload ~/Library/LaunchAgents/com.alleFind.zsxq-daily.plist
 ============================================================
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.alleFind.zsxq-daily</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/Users/YOURNAME/trading-research-toolkit/scripts/zsxq/zsxq_daily.sh</string>
    </array>

    <!-- 每天 04:00 触发（凌晨低峰，星球风控最宽松）-->
    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>4</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>

    <!-- 如果 Mac 在触发时间已关机，下次开机会补跑 -->
    <key>RunAtLoad</key>
    <false/>

    <!-- 防止并发（Mac 唤醒时可能短时间内多次触发）-->
    <key>ThrottleInterval</key>
    <integer>3600</integer>

    <!-- 工作目录 -->
    <key>WorkingDirectory</key>
    <string>/Users/YOURNAME/trading-research-toolkit/scripts/zsxq</string>

    <!-- 环境变量。如果 uv 装在 brew，PATH 必须包含 -->
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/Users/YOURNAME/.local/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
        <key>HOME</key>
        <string>/Users/YOURNAME</string>
    </dict>

    <!-- 输出和错误统一写到 /tmp -->
    <key>StandardOutPath</key>
    <string>/tmp/zsxq-daily.log</string>

    <key>StandardErrorPath</key>
    <string>/tmp/zsxq-daily.err</string>
</dict>
</plist>
